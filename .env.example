# ASR API 服务配置
# 复制此文件为 .env 并填写实际值

# 服务器设置
API_HOST=0.0.0.0
API_PORT=8000

# 模型路径（默认即可）
MODEL_PATH=models/Qwen3-ASR-1.7B
ALIGNER_PATH=models/Qwen3-ForcedAligner-0.6B

# 目录设置
TEMP_DIR=temp
RESULTS_DIR=results
OUTPUT_DIR=output

# LLM 默认配置（可选，前端可覆盖）
LLM_API_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL_NAME=deepseek-chat
